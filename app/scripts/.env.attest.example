# Copie ce fichier en .env.attest et remplis les valeurs.
# IMPORTANT : ne commit JAMAIS .env.attest — il contient ta clé privée.

# Clé privée de ton wallet Optimism (hex, SANS le préfixe 0x)
# Wallet : 0xA1B2f32a71ef4117D0e16Fc50574E37862B4Df30
EVM_PRIVATE_KEY=

# Chemin absolu vers ton fichier keypair Solana JSON
# Génère-le si besoin : solana-keygen new -o ~/.config/solana/attest.json
# Wallet : CL4yt4Ep6N3AKbbHhQaidjVLNzQrdgT5NobQSE6FGHr3
SOLANA_KEYPAIR=/Users/hchstudio/.config/solana/id.json
